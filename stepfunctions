{
  "StartAt": "CreateJob",
  "States": {
    "CreateJob": {
      "Type": "Task",
      "Resource": "arn:aws:states:::mediaconvert:createJob.sync",
      "Arguments": {
        "JobTemplate": "arn:aws:mediaconvert:ap-northeast-1:xxxxxxxxxxxxxxx:jobTemplates/xxxxxxxxxxxxxxxxxxxxx",
        "Queue": "arn:aws:mediaconvert:ap-northeast-1:xxxxxxxxxxxxxxx:queues/xxxxxxxxxxxxxxxxxx",
        "Role": "arn:aws:iam::xxxxxxxxxxxxxxxx:role/service-role/MediaConvert_Default_Role",
        "Settings": {
          "Inputs": [
            {
              "FileInput": "{% 's3://' & $states.input.detail.bucket.name & '/' & $states.input.detail.object.key %}"
            }
          ]
        },
        "Tags": {
          "Cost": "example-dev"
        }
      },
      "End": true,
      "QueryLanguage": "JSONata",
      "TimeoutSeconds": 600
    }
  },
  "TimeoutSeconds": 660,
  "Comment": "For converting a MP4 media to HLS (ABR 360p/720p)"
}
