{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Action": [
				"s3:GetObject"
			],
			"Resource": [
				"arn:aws:s3:::<S3Buckt-name>/mp4/*"
			],
			"Effect": "Allow"
		},
		{
			"Action": [
				"s3:PutObject"
			],
			"Resource": [
				"arn:aws:s3:::<S3Buckt-name>/convert/*"
			],
			"Effect": "Allow"
		},
		{
			"Action": [
				"events:PutTargets",
				"events:PutRule",
				"events:DescribeRule"
			],
			"Resource": [
				"arn:aws:events:ap-northeast-1:<AccountID>:rule/StepFunctionsGetEventsForMediaConvertJobRule"
			],
			"Effect": "Allow"
		}
	]
}
